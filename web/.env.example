# Supabase-Projekt-Zugangsdaten
# Zu finden im Supabase-Dashboard unter: Project Settings -> API

# Project URL (z. B. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# "anon public" Key - darf im Browser sichtbar sein (RLS schuetzt die Daten)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" Key - GEHEIM, niemals im Browser verwenden!
# Wird nur serverseitig genutzt (z. B. fuer Nutzer-Einladungen).
SUPABASE_SERVICE_ROLE_KEY=

# Basis-URL der App (fuer Einladungs-Links in E-Mails).
# Lokal: http://localhost:3000 - nach dem Deployment: die echte Domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
